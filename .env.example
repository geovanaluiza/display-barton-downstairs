# Northwest University — display-barton-downstairs
#
# These are the Supabase environment variables used by the heartbeat
# client (composables/useDisplayHeartbeat.ts) and the security monitor
# (lib/securityMonitor.ts). Set them in your local .env for
# development and in the Vercel project settings for the production
# deployment.
#
# Do NOT commit a real .env file. .env is in .gitignore.
VITE_SUPABASE_URL=https://vdhufxbctleyhjauvcoq.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_Irtj1fgbS6ZmYB3sFN2f1g_fAJnX-To

# Phase 4.5 — Security monitor. The kiosk considers any URL whose
# origin does NOT match this value as a kiosk escape and
# auto-recovers to VITE_DISPLAY_APPROVED_URL + VITE_DISPLAY_HOME_PATH
# (default '/'). Leave blank to use the build-time default.
VITE_DISPLAY_APPROVED_URL=https://display-barton-downstairs.vercel.app